{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "gitleaks",
          "semanticVersion": "8.27.2",
          "rules": [
            {
              "id": "generic-api-key",
              "name": "Generic API key"
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "generic-api-key",
          "message": {
            "text": "Generic API key"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "config/example.env"
                },
                "region": {
                  "startLine": 3
                }
              }
            }
          ],
          "properties": {
            "Secret": "<redacted-secret-fingerprint>"
          },
          "fingerprints": {
            "gitleaksFingerprint": "0000000000000000000000000000000000000000:config/example.env:generic-api-key:3"
          }
        }
      ]
    }
  ]
}
