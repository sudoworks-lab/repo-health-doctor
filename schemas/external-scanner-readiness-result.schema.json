{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-health-doctor://schemas/external-scanner-readiness-result.schema.json",
  "title": "repo-health-doctor external scanner execution readiness result",
  "type": "object",
  "required": [
    "schema_version",
    "report_kind",
    "ready",
    "execution_authorized",
    "blocking_errors",
    "warnings",
    "required_approvals",
    "approval_present",
    "scanner_executed",
    "network_allowed",
    "target_code_execution_allowed",
    "docker_allowed",
    "raw_output_retention",
    "raw_output_discard_required",
    "requires_human_approval",
    "binary_trust_status",
    "version_pin_status",
    "binary_hash_status",
    "policy_version",
    "limitations",
    "residual_risks"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["0.1-draft"]},
    "report_kind": {"type": "string", "enum": ["external_scanner_execution_readiness"]},
    "ready": {"type": "boolean"},
    "execution_authorized": {"type": "boolean", "const": false},
    "blocking_errors": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "required_approvals": {"type": "array", "items": {"type": "string"}},
    "approval_present": {"type": "boolean"},
    "scanner_executed": {"type": "boolean"},
    "network_allowed": {"type": "boolean"},
    "target_code_execution_allowed": {"type": "boolean"},
    "docker_allowed": {"type": "boolean"},
    "raw_output_retention": {"type": "boolean"},
    "raw_output_discard_required": {"type": "boolean"},
    "requires_human_approval": {"type": "boolean"},
    "binary_trust_status": {"type": "string"},
    "version_pin_status": {"type": "string"},
    "binary_hash_status": {"type": "string"},
    "policy_version": {"type": ["string", "null"]},
    "limitations": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "residual_risks": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "additionalProperties": false
}
