{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-health-doctor://schemas/sandbox-image-lock.schema.json",
  "title": "repo-health-doctor sandbox image lock",
  "type": "object",
  "required": ["schema_version", "report_kind", "lock_id", "images", "version_metadata", "required_runtime_flags", "binding_contract", "residual_risks"],
  "properties": {"schema_version": {"type": "string", "enum": ["0.1-draft"]}, "report_kind": {"type": "string", "enum": ["sandbox_image_lock"]}, "lock_id": {"type": "string"}, "images": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/image"}}, "version_metadata": {"$ref": "#/$defs/version"}, "required_runtime_flags": {"$ref": "#/$defs/runtime_flags"}, "binding_contract": {"$ref": "#/$defs/binding"}, "residual_risks": {"type": "array", "minItems": 1, "items": {"type": "string"}}},
  "additionalProperties": false,
  "$defs": {
    "image": {"type": "object", "required": ["logical_name", "distribution", "registry_reference", "registry_digest", "expected_image_id", "purpose", "supported_phases", "supported_runtimes", "tool_versions", "expected_platform", "source_build_metadata", "local_sanctioned_allowed", "local_sanctioned_limitations"], "properties": {"logical_name": {"type": "string"}, "distribution": {"type": "string", "enum": ["registry_primary", "local_dev_only"]}, "registry_reference": {"type": "string"}, "registry_digest": {"type": ["string", "null"]}, "expected_image_id": {"type": ["string", "null"]}, "purpose": {"type": "string"}, "supported_phases": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "supported_runtimes": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "tool_versions": {"$ref": "#/$defs/tools"}, "expected_platform": {"$ref": "#/$defs/platform"}, "source_build_metadata": {"$ref": "#/$defs/source"}, "local_sanctioned_allowed": {"type": "boolean"}, "local_sanctioned_limitations": {"type": "array", "items": {"type": "string"}}}, "additionalProperties": false},
    "tools": {"type": "object", "required": ["python", "node", "strace", "pip", "npm", "other"], "properties": {"python": {"type": "string"}, "node": {"type": "string"}, "strace": {"type": "string"}, "pip": {"type": "string"}, "npm": {"type": "string"}, "other": {"type": "string"}}, "additionalProperties": false},
    "platform": {"type": "object", "required": ["os", "architecture"], "properties": {"os": {"type": "string", "enum": ["linux"]}, "architecture": {"type": "string", "enum": ["amd64", "arm64"]}}, "additionalProperties": false},
    "source": {"type": "object", "required": ["source", "build_reference"], "properties": {"source": {"type": "string"}, "build_reference": {"type": "string"}}, "additionalProperties": false},
    "version": {"type": "object", "required": ["created_at", "updated_at", "source"], "properties": {"created_at": {"type": "string"}, "updated_at": {"type": "string"}, "source": {"type": "string"}}, "additionalProperties": false},
    "runtime_flags": {"type": "object", "required": ["pull_policy", "network", "shell", "host_home", "docker_socket"], "properties": {"pull_policy": {"type": "string", "enum": ["never"]}, "network": {"type": "string", "enum": ["none"]}, "shell": {"type": "boolean", "enum": [false]}, "host_home": {"type": "boolean", "enum": [false]}, "docker_socket": {"type": "boolean", "enum": [false]}}, "additionalProperties": false},
    "binding": {"type": "object", "required": ["approval_draft_report_kind", "behavior_policy_report_kind", "behavior_policy_schema_version", "image_lock_schema_version", "candidate_key_includes"], "properties": {"approval_draft_report_kind": {"type": "string", "enum": ["sandbox_approval_draft"]}, "behavior_policy_report_kind": {"type": "string", "enum": ["sandbox_command_behavior_policy"]}, "behavior_policy_schema_version": {"type": "string", "enum": ["0.1-draft"]}, "image_lock_schema_version": {"type": "string", "enum": ["0.1-draft"]}, "candidate_key_includes": {"type": "array", "items": {"type": "string"}}}, "additionalProperties": false}
  }
}
