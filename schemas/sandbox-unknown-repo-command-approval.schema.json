{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-health-doctor://schemas/sandbox-unknown-repo-command-approval.schema.json",
  "title": "repo-health-doctor unknown repository command approval",
  "type": "object",
  "required": ["schema_version", "report_kind", "approval_id", "approved", "approval_status", "approval_scope", "repo_scope", "source_approval_draft", "source_profile_report", "source_risk_tier", "command", "image_lock_binding", "behavior_policy_binding", "candidate_key", "exact_match_key", "lifecycle", "human_review_requirements", "revocation", "t3_exception", "limitations", "residual_risks"],
  "properties": {"schema_version": {"type": "string", "enum": ["0.1-draft"]}, "report_kind": {"type": "string", "enum": ["sandbox_unknown_repo_command_approval"]}, "approval_id": {"type": "string"}, "approved": {"type": "boolean", "enum": [true]}, "approval_status": {"type": "string", "enum": ["approved_human_reviewed"]}, "approval_scope": {"$ref": "#/$defs/scope"}, "repo_scope": {"$ref": "#/$defs/repo"}, "source_approval_draft": {"$ref": "#/$defs/draft"}, "source_profile_report": {"$ref": "#/$defs/profile"}, "source_risk_tier": {"type": "string", "enum": ["T1", "T2", "T3"]}, "command": {"$ref": "#/$defs/command"}, "image_lock_binding": {"$ref": "#/$defs/image"}, "behavior_policy_binding": {"$ref": "#/$defs/policy"}, "candidate_key": {"type": "string", "pattern": "^sha256:"}, "exact_match_key": {"type": "string", "pattern": "^sha256:"}, "lifecycle": {"$ref": "#/$defs/lifecycle"}, "human_review_requirements": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "revocation": {"$ref": "#/$defs/revocation"}, "t3_exception": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/t3_exception"}]}, "limitations": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "residual_risks": {"type": "array", "minItems": 1, "items": {"type": "string"}}},
  "additionalProperties": false,
  "$defs": {
    "scope": {"type": "object", "required": ["scope", "phase", "kind"], "properties": {"scope": {"type": "string", "enum": ["single_command"]}, "phase": {"type": "string", "enum": ["phase2_install_probe", "phase3_runtime_probe"]}, "kind": {"type": "string"}}, "additionalProperties": false},
    "repo": {"type": "object", "required": ["repository_identity", "commit", "path", "working_tree_status"], "properties": {"repository_identity": {"type": "string", "pattern": "^sha256:"}, "commit": {"type": "string"}, "path": {"type": "string", "enum": ["<repo>"]}, "working_tree_status": {"type": "string", "enum": ["clean_verified"]}}, "additionalProperties": false},
    "draft": {"type": "object", "required": ["schema_version", "report_kind", "candidate_key", "exact_match_key"], "properties": {"schema_version": {"type": "string", "enum": ["0.1-draft"]}, "report_kind": {"type": "string", "enum": ["sandbox_approval_draft"]}, "candidate_key": {"type": "string"}, "exact_match_key": {"type": "string"}}, "additionalProperties": false},
    "profile": {"type": "object", "required": ["schema_version", "report_kind", "repository_identity"], "properties": {"schema_version": {"type": "string", "enum": ["0.1-draft"]}, "report_kind": {"type": "string", "enum": ["sandbox_unknown_repo_profile"]}, "repository_identity": {"type": "string"}}, "additionalProperties": false},
    "command": {"type": "object", "required": ["phase", "kind", "cwd", "argv", "env_allowlist", "shell", "network_policy"], "properties": {"phase": {"type": "string", "enum": ["phase2_install_probe", "phase3_runtime_probe"]}, "kind": {"type": "string"}, "cwd": {"type": "string", "pattern": "^/workspace(?:/.*)?$"}, "argv": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "env_allowlist": {"type": "array", "items": {"type": "string"}}, "shell": {"type": "boolean", "enum": [false]}, "network_policy": {"type": "string", "enum": ["none"]}}, "additionalProperties": false},
    "image": {"type": "object", "required": ["schema_version", "report_kind", "lock_id", "registry_digest", "expected_image_id", "platform", "tool_versions", "pull_policy"], "properties": {"schema_version": {"type": "string", "enum": ["0.1-draft"]}, "report_kind": {"type": "string", "enum": ["sandbox_image_lock"]}, "lock_id": {"type": "string"}, "registry_digest": {"type": ["string", "null"]}, "expected_image_id": {"type": ["string", "null"]}, "platform": {"type": "object"}, "tool_versions": {"type": "object"}, "pull_policy": {"type": "string", "enum": ["never"]}}, "additionalProperties": false},
    "policy": {"type": "object", "required": ["schema_version", "report_kind", "policy_id", "binding_fingerprint"], "properties": {"schema_version": {"type": "string", "enum": ["0.1-draft"]}, "report_kind": {"type": "string", "enum": ["sandbox_command_behavior_policy"]}, "policy_id": {"type": "string"}, "binding_fingerprint": {"type": "string", "pattern": "^sha256:"}}, "additionalProperties": false},
    "lifecycle": {"type": "object", "required": ["created_at", "expires_at", "created_by", "reviewed_by", "reviewed_at", "review_rationale", "review_evidence_handle"], "properties": {"created_at": {"type": "string"}, "expires_at": {"type": "string"}, "created_by": {"type": "string"}, "reviewed_by": {"type": "string"}, "reviewed_at": {"type": "string"}, "review_rationale": {"type": "string"}, "review_evidence_handle": {"type": "string"}}, "additionalProperties": false},
    "revocation": {"type": "object", "required": ["state", "invalidation_conditions"], "properties": {"state": {"type": "string", "enum": ["active"]}, "invalidation_conditions": {"type": "array", "minItems": 1, "items": {"type": "string"}}}, "additionalProperties": false},
    "t3_exception": {"type": "object", "required": ["exception_rationale", "exception_scope", "phase1_required", "phase1_5_required", "subprocess_allowlist", "stronger_isolation_required", "expiry", "reviewers", "network_none_required", "shell_false_required", "disallowed_if_direct_url_or_vcs_or_credential_or_obfuscation"], "properties": {"exception_rationale": {"type": "string"}, "exception_scope": {"type": "string"}, "phase1_required": {"type": "boolean", "enum": [true]}, "phase1_5_required": {"type": "boolean", "enum": [true]}, "subprocess_allowlist": {"type": "array", "items": {"type": "string"}}, "stronger_isolation_required": {"type": "boolean", "enum": [true]}, "expiry": {"type": "string"}, "reviewers": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "network_none_required": {"type": "boolean", "enum": [true]}, "shell_false_required": {"type": "boolean", "enum": [true]}, "disallowed_if_direct_url_or_vcs_or_credential_or_obfuscation": {"type": "boolean", "enum": [true]}}, "additionalProperties": false}
  }
}
