{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-health-doctor://schemas/sandbox-run.schema.json",
  "title": "Docker sandbox-run v1 evidence report",
  "type": "object",
  "required": [
    "schema_version",
    "report_kind",
    "kind",
    "tool",
    "version",
    "experimental",
    "contract",
    "run",
    "target",
    "verified_snapshot",
    "subject_consistency",
    "approval",
    "gate",
    "authorization",
    "sandbox_profile",
    "seccomp",
    "command",
    "docker",
    "disposable_workspace",
    "workspace_diff",
    "result",
    "policy_blocked",
    "command_started",
    "command_start_state",
    "command_exit_code",
    "sandbox_exit_code",
    "block_reason",
    "output_summary",
    "runtime_write_budget",
    "env_policy",
    "cleanup_policy",
    "boundary_statement",
    "limitations",
    "next_actions",
    "safety_statement"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "enum": ["0.1-draft"]},
    "report_kind": {"type": "string", "enum": ["sandbox_run"]},
    "report_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "kind": {"type": "string", "enum": ["sandbox_run"]},
    "tool": {"type": "string", "enum": ["repo-health-doctor"]},
    "version": {"type": "string"},
    "experimental": {"type": "boolean"},
    "contract": {"type": "object"},
    "run": {"type": "object"},
    "target": {"type": "object"},
    "verified_snapshot": {
      "type": "object",
      "required": [
        "schema_version",
        "snapshot_id",
        "manifest_fingerprint",
        "integrity_status",
        "limitations",
        "refusal_reasons",
        "integrity_after_execution"
      ],
      "properties": {
        "schema_version": {"type": "string", "const": "1.0"},
        "snapshot_id": {
          "type": ["string", "null"],
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "manifest_fingerprint": {
          "type": ["string", "null"],
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "integrity_status": {
          "type": "string",
          "enum": ["verified", "invalid"]
        },
        "integrity_after_execution": {
          "type": "string",
          "enum": ["not_checked", "verified", "mismatch"]
        },
        "limitations": {"type": "array", "items": {"type": "string"}},
        "refusal_reasons": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "subject_consistency": {
      "type": "object",
      "required": [
        "consistent",
        "scan_snapshot_id",
        "gate_snapshot_id",
        "authorization_snapshot_id",
        "workspace_snapshot_id",
        "evidence_snapshot_id",
        "scan_manifest_fingerprint",
        "gate_manifest_fingerprint",
        "authorization_manifest_fingerprint",
        "workspace_manifest_fingerprint",
        "evidence_manifest_fingerprint",
        "actual_source_kind_is_git_commit",
        "runtime_fields_resolved",
        "gate_field_matches",
        "authorization_field_matches",
        "gate_matches",
        "authorization_matches",
        "missing_or_unresolved"
      ],
      "properties": {
        "consistent": {"type": "boolean"},
        "scan_snapshot_id": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"},
        "gate_snapshot_id": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"},
        "authorization_snapshot_id": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"},
        "workspace_snapshot_id": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"},
        "evidence_snapshot_id": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"},
        "scan_manifest_fingerprint": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"},
        "gate_manifest_fingerprint": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"},
        "authorization_manifest_fingerprint": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"},
        "workspace_manifest_fingerprint": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"},
        "evidence_manifest_fingerprint": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"},
        "actual_source_kind_is_git_commit": {"type": "boolean"},
        "runtime_fields_resolved": {"$ref": "#/$defs/fiveFieldMatches"},
        "gate_field_matches": {"$ref": "#/$defs/fiveFieldMatches"},
        "authorization_field_matches": {"$ref": "#/$defs/fiveFieldMatches"},
        "gate_matches": {"type": "boolean"},
        "authorization_matches": {"type": "boolean"},
        "missing_or_unresolved": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "approval": {"type": "object"},
    "gate": {"type": "object"},
    "authorization": {"type": "object"},
    "sandbox_profile": {"type": "object"},
    "seccomp": {
      "type": "object",
      "required": ["profile", "profile_sha256", "source"],
      "additionalProperties": false,
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["runtime-default", "rhd-moby-default-v1", "rhd-locked-down-v1"]
        },
        "profile_sha256": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$"
        },
        "source": {
          "type": "string",
          "enum": ["runtime_default", "package_data"]
        }
      },
      "oneOf": [
        {
          "properties": {
            "profile": {"const": "runtime-default"},
            "profile_sha256": {"const": null},
            "source": {"const": "runtime_default"}
          }
        },
        {
          "properties": {
            "profile": {"const": "rhd-moby-default-v1"},
            "profile_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "source": {"const": "package_data"}
          }
        },
        {
          "properties": {
            "profile": {"const": "rhd-locked-down-v1"},
            "profile_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "source": {"const": "package_data"}
          }
        }
      ]
    },
    "command": {"type": "object"},
    "docker": {
      "type": "object",
      "required": [
        "image",
        "pull_policy",
        "network",
        "argv_redacted",
        "runner",
        "invoked",
        "docker_invoked",
        "exit_code",
        "failure_class",
        "diagnostic_redacted",
        "stdout_preview_redacted",
        "stderr_preview_redacted",
        "container_tracking_enabled",
        "cleanup_attempted",
        "cleanup_status",
        "cleanup_failure_class",
        "command_start_state",
        "stdout_bytes",
        "stderr_bytes",
        "total_output_bytes",
        "stdout_truncated",
        "stderr_truncated",
        "output_budget_exceeded"
      ],
      "properties": {
        "image": {"type": "string"},
        "image_digest_pinned": {"type": "boolean"},
        "latest_tag": {"type": "boolean"},
        "pull_policy": {"type": "string", "enum": ["never"]},
        "network": {"type": "string"},
        "workdir": {"type": "string"},
        "mounts_summary": {"type": "object"},
        "resource_limits": {"type": "object"},
        "security_options": {"type": "object"},
        "user": {"type": "string"},
        "root_container_user": {"type": "boolean"},
        "rootless_docker_detected": {"type": "string"},
        "userns_remap_detected": {"type": "string"},
        "argv_redacted": {"type": "array", "items": {"type": "string"}},
        "runner": {"type": "string"},
        "invoked": {"type": "boolean"},
        "docker_invoked": {"type": "boolean"},
        "exit_code": {"type": ["integer", "null"]},
        "failure_class": {"type": ["string", "null"]},
        "diagnostic_redacted": {"type": ["string", "null"]},
        "stdout_preview_redacted": {"type": "string"},
        "stderr_preview_redacted": {"type": "string"},
        "container_tracking_enabled": {"type": "boolean"},
        "cleanup_attempted": {"type": "boolean"},
        "cleanup_status": {"type": "string", "enum": ["not_attempted", "ok", "failed"]},
        "cleanup_failure_class": {"type": ["string", "null"]},
        "command_start_state": {"type": "string", "enum": ["not_started", "confirmed", "unknown"]},
        "stdout_bytes": {"type": "integer", "minimum": 0},
        "stderr_bytes": {"type": "integer", "minimum": 0},
        "total_output_bytes": {"type": "integer", "minimum": 0},
        "stdout_truncated": {"type": "boolean"},
        "stderr_truncated": {"type": "boolean"},
        "output_budget_exceeded": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "disposable_workspace": {"type": "object"},
    "workspace_diff": {"type": "object"},
    "result": {
      "type": "object",
      "required": ["status", "exit_code", "timed_out", "duration_ms"],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "blocked",
            "completed",
            "failed",
            "dry_run",
            "timed_out",
            "output_budget_exceeded",
            "observer_degraded",
            "cleanup_uncertain",
            "redaction_failed"
          ]
        },
        "exit_code": {"type": ["integer", "null"]},
        "timed_out": {"type": "boolean"},
        "duration_ms": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "policy_blocked": {"type": "boolean"},
    "command_started": {"type": "boolean"},
    "command_start_state": {"type": "string", "enum": ["not_started", "confirmed", "unknown"]},
    "command_exit_code": {"type": ["integer", "null"]},
    "sandbox_exit_code": {"type": "integer"},
    "block_reason": {"type": ["string", "null"]},
    "output_summary": {
      "type": "object",
      "required": [
        "stdout_preview_redacted",
        "stderr_preview_redacted",
        "stdout_truncated",
        "stderr_truncated",
        "stdout_bytes",
        "stderr_bytes",
        "total_output_bytes",
        "stdout_byte_budget",
        "stderr_byte_budget",
        "total_byte_budget",
        "preview_char_budget",
        "read_chunk_bytes",
        "output_budget_exceeded",
        "stdout_budget_exceeded",
        "stderr_budget_exceeded",
        "redaction_applied",
        "redaction_failure",
        "raw_stdout_stderr_persisted"
      ],
      "properties": {
        "stdout_preview_redacted": {"type": "string"},
        "stderr_preview_redacted": {"type": "string"},
        "stdout_truncated": {"type": "boolean"},
        "stderr_truncated": {"type": "boolean"},
        "stdout_bytes": {"type": "integer", "minimum": 0},
        "stderr_bytes": {"type": "integer", "minimum": 0},
        "total_output_bytes": {"type": "integer", "minimum": 0},
        "stdout_byte_budget": {"type": "integer", "minimum": 1},
        "stderr_byte_budget": {"type": "integer", "minimum": 1},
        "total_byte_budget": {"type": "integer", "minimum": 1},
        "preview_char_budget": {"type": "integer", "minimum": 1},
        "read_chunk_bytes": {"type": "integer", "minimum": 1},
        "output_budget_exceeded": {"type": "boolean"},
        "stdout_budget_exceeded": {"type": "boolean"},
        "stderr_budget_exceeded": {"type": "boolean"},
        "redaction_applied": {"type": "boolean"},
        "redaction_failure": {"type": ["string", "null"]},
        "raw_stdout_stderr_persisted": {"type": "boolean", "const": false}
      },
      "additionalProperties": false
    },
    "runtime_write_budget": {
      "type": "object",
      "required": ["enforcement", "polling_watchdog", "overshoot_limitation", "paths"],
      "properties": {
        "enforcement": {"type": "string"},
        "polling_watchdog": {"type": "boolean"},
        "poll_interval_ms": {"type": ["integer", "null"]},
        "scan_budget": {"type": ["integer", "null"]},
        "overshoot_limitation": {"type": "string"},
        "paths": {
          "type": "object",
          "required": ["workspace", "out"],
          "properties": {
            "workspace": {"$ref": "#/$defs/runtimeWritePath"},
            "out": {"$ref": "#/$defs/runtimeWritePath"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "env_policy": {"type": "object"},
    "cleanup_policy": {"type": "object"},
    "boundary_statement": {"type": "object"},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "next_actions": {"type": "array", "items": {"type": "string"}},
    "safety_statement": {"type": "string"}
  },
  "$defs": {
    "runtimeWritePath": {
      "type": "object",
      "required": ["host_backed", "mount", "read_only", "max_bytes", "max_files", "observed_bytes", "observed_files", "exceeded"],
      "properties": {
        "host_backed": {"type": "boolean"},
        "mount": {"type": "string"},
        "read_only": {"type": "boolean"},
        "max_bytes": {"type": "integer", "minimum": 0},
        "max_files": {"type": "integer", "minimum": 0},
        "observed_bytes": {"type": ["integer", "null"], "minimum": 0},
        "observed_files": {"type": ["integer", "null"], "minimum": 0},
        "exceeded": {"type": ["boolean", "null"]},
        "kernel_enforced": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "fiveFieldMatches": {
      "type": "object",
      "required": [
        "repository_identity",
        "commit",
        "tree",
        "snapshot_id",
        "manifest_fingerprint"
      ],
      "properties": {
        "repository_identity": {"type": "boolean"},
        "commit": {"type": "boolean"},
        "tree": {"type": "boolean"},
        "snapshot_id": {"type": "boolean"},
        "manifest_fingerprint": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  }
}
