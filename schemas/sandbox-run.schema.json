{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-health-doctor://schemas/sandbox-run.schema.json",
  "title": "Experimental Docker sandbox-run report",
  "type": "object",
  "required": [
    "schema_version",
    "report_kind",
    "kind",
    "tool",
    "version",
    "experimental",
    "target",
    "approval",
    "sandbox_profile",
    "command",
    "docker",
    "disposable_workspace",
    "workspace_diff",
    "result",
    "output_summary",
    "boundary_statement",
    "limitations",
    "next_actions",
    "safety_statement"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "enum": ["0.1-draft"]},
    "report_kind": {"type": "string", "enum": ["sandbox_run"]},
    "kind": {"type": "string", "enum": ["sandbox_run"]},
    "tool": {"type": "string", "enum": ["repo-health-doctor"]},
    "version": {"type": "string"},
    "experimental": {"type": "boolean", "const": true},
    "target": {"type": "object"},
    "approval": {"type": "object"},
    "sandbox_profile": {"type": "object"},
    "command": {"type": "object"},
    "docker": {
      "type": "object",
      "required": [
        "image",
        "pull_policy",
        "network",
        "argv_redacted",
        "runner",
        "invoked",
        "docker_invoked",
        "exit_code",
        "failure_class",
        "diagnostic_redacted",
        "stdout_preview_redacted",
        "stderr_preview_redacted"
      ],
      "properties": {
        "image": {"type": "string"},
        "image_digest_pinned": {"type": "boolean"},
        "latest_tag": {"type": "boolean"},
        "pull_policy": {"type": "string", "enum": ["never"]},
        "network": {"type": "string"},
        "workdir": {"type": "string"},
        "mounts_summary": {"type": "object"},
        "resource_limits": {"type": "object"},
        "security_options": {"type": "object"},
        "user": {"type": "string"},
        "root_container_user": {"type": "boolean"},
        "rootless_docker_detected": {"type": "string"},
        "userns_remap_detected": {"type": "string"},
        "argv_redacted": {"type": "array", "items": {"type": "string"}},
        "runner": {"type": "string"},
        "invoked": {"type": "boolean"},
        "docker_invoked": {"type": "boolean"},
        "exit_code": {"type": ["integer", "null"]},
        "failure_class": {"type": ["string", "null"]},
        "diagnostic_redacted": {"type": ["string", "null"]},
        "stdout_preview_redacted": {"type": "string"},
        "stderr_preview_redacted": {"type": "string"}
      },
      "additionalProperties": true
    },
    "disposable_workspace": {"type": "object"},
    "workspace_diff": {"type": "object"},
    "result": {
      "type": "object",
      "required": ["status", "exit_code", "timed_out", "duration_ms"],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "blocked",
            "completed",
            "failed",
            "timed_out",
            "observer_degraded",
            "cleanup_uncertain",
            "redaction_failed"
          ]
        },
        "exit_code": {"type": ["integer", "null"]},
        "timed_out": {"type": "boolean"},
        "duration_ms": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "output_summary": {
      "type": "object",
      "required": [
        "stdout_preview_redacted",
        "stderr_preview_redacted",
        "stdout_truncated",
        "stderr_truncated",
        "redaction_applied",
        "redaction_failure",
        "raw_stdout_stderr_persisted"
      ],
      "properties": {
        "stdout_preview_redacted": {"type": "string"},
        "stderr_preview_redacted": {"type": "string"},
        "stdout_truncated": {"type": "boolean"},
        "stderr_truncated": {"type": "boolean"},
        "redaction_applied": {"type": "boolean"},
        "redaction_failure": {"type": ["string", "null"]},
        "raw_stdout_stderr_persisted": {"type": "boolean", "const": false}
      },
      "additionalProperties": false
    },
    "boundary_statement": {"type": "object"},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "next_actions": {"type": "array", "items": {"type": "string"}},
    "safety_statement": {"type": "string"}
  }
}
