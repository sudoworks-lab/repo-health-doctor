{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-health-doctor://schemas/gate-decision.schema.json",
  "title": "repo-health-doctor gate decision",
  "description": "Experimental draft gate decision sidecar schema. Gate decisions are review outcomes and always keep execution_authorized=false.",
  "type": "object",
  "required": [
    "decision_kind",
    "schema_version",
    "subject",
    "verdict",
    "execution_authorized",
    "confidence",
    "confidence_reason",
    "explanation",
    "evidence_summary",
    "required_actions",
    "limitations",
    "policy",
    "residual_risks"
  ],
  "properties": {
    "decision_kind": {"type": "string", "enum": ["repo_health_gate_decision"]},
    "schema_version": {"type": "string", "enum": ["0.1-draft"]},
    "subject": {"$ref": "#/$defs/subject"},
    "verdict": {
      "type": "string",
      "enum": ["allow_limited", "warn", "quarantine", "block", "unknown"]
    },
    "execution_authorized": {"type": "boolean", "const": false},
    "confidence": {"type": "string", "enum": ["low", "medium", "high", "unknown"]},
    "confidence_reason": {"type": "string", "minLength": 1},
    "explanation": {"$ref": "#/$defs/explanation"},
    "evidence_summary": {"$ref": "#/$defs/evidence_summary"},
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {"$ref": "#/$defs/evidence_ref"}
    },
    "required_actions": {"type": "array", "items": {"type": "string"}},
    "limitations": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "policy": {"$ref": "#/$defs/policy"},
    "residual_risks": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false,
  "$defs": {
    "subject": {
      "type": "object",
      "required": ["repo", "commit", "tree_hash", "binding_kind"],
      "properties": {
        "repo": {"type": "string", "minLength": 1},
        "commit": {"type": ["string", "null"]},
        "tree_hash": {"type": ["string", "null"]},
        "binding_kind": {
          "type": "string",
          "enum": ["unbound", "path_bound", "commit_bound", "tree_bound", "synthetic"]
        }
      },
      "additionalProperties": false
    },
    "explanation": {
      "type": "object",
      "required": ["summary", "key_reasons", "next_actions"],
      "properties": {
        "summary": {"type": "string", "minLength": 1},
        "key_reasons": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "next_actions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    },
    "evidence_summary": {
      "type": "object",
      "required": [
        "findings_count",
        "blocking_evidence",
        "warning_evidence",
        "missing_evidence",
        "degraded_observers"
      ],
      "properties": {
        "findings_count": {"type": "integer", "minimum": 0},
        "blocking_evidence": {"type": "array", "items": {"type": "string"}},
        "warning_evidence": {"type": "array", "items": {"type": "string"}},
        "missing_evidence": {"type": "array", "items": {"type": "string"}},
        "degraded_observers": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "evidence_ref": {
      "oneOf": [
        {"$ref": "#/$defs/external_evidence_ref"},
        {"$ref": "#/$defs/sandbox_evidence_ref"}
      ]
    },
    "external_evidence_ref": {
      "type": "object",
      "required": [
        "report_kind",
        "report_fingerprint",
        "generated_at",
        "subject",
        "size_bytes",
        "truncated",
        "validation_status",
        "reasons"
      ],
      "properties": {
        "report_kind": {"type": ["string", "null"], "enum": ["real_scanner_suite", null]},
        "report_fingerprint": {
          "type": ["string", "null"],
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "generated_at": {"type": ["string", "null"], "format": "date-time"},
        "subject": {
          "type": "object",
          "properties": {
            "repo_commit": {
              "type": ["string", "null"],
              "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"
            },
            "dirty_state": {
              "type": "string",
              "enum": ["clean", "dirty", "unknown", "not_applicable"]
            }
          },
          "additionalProperties": false
        },
        "size_bytes": {"type": ["integer", "null"], "minimum": 0},
        "truncated": {"type": "boolean"},
        "validation_status": {"type": "string", "enum": ["valid", "invalid"]},
        "reasons": {
          "type": "array",
          "maxItems": 7,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "external_evidence_invalid",
              "external_evidence_fingerprint_mismatch",
              "external_evidence_stale",
              "external_evidence_subject_mismatch",
              "external_evidence_over_budget",
              "external_evidence_duplicate",
              "external_evidence_truncated"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "sandbox_evidence_ref": {
      "type": "object",
      "required": [
        "report_kind",
        "report_fingerprint",
        "run_id",
        "gate_decision_fingerprint",
        "validation_status",
        "reasons"
      ],
      "properties": {
        "report_kind": {"type": "string", "const": "sandbox_run"},
        "report_fingerprint": {
          "type": ["string", "null"],
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "run_id": {
          "type": ["string", "null"],
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "gate_decision_fingerprint": {
          "type": ["string", "null"],
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "validation_status": {"type": "string", "enum": ["valid", "invalid"]},
        "reasons": {
          "type": "array",
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "sandbox_evidence_invalid",
              "sandbox_evidence_fingerprint_mismatch",
              "sandbox_evidence_stale",
              "sandbox_evidence_subject_mismatch",
              "sandbox_evidence_policy_mismatch",
              "sandbox_evidence_over_budget",
              "sandbox_evidence_duplicate",
              "sandbox_evidence_truncated"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "policy": {
      "type": "object",
      "required": ["policy_version", "fail_closed"],
      "properties": {
        "policy_version": {"type": ["string", "null"]},
        "fail_closed": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  }
}
