{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-health-doctor://schemas/evidence.schema.json",
  "title": "repo-health-doctor evidence",
  "description": "Experimental draft evidence schema. The stable compatibility output remains the default v3 JSON report.",
  "type": "object",
  "required": [
    "evidence_id",
    "schema_version",
    "evidence_kind",
    "source",
    "subject",
    "classification",
    "finding",
    "raw_handling",
    "trust",
    "effects",
    "residual_risks"
  ],
  "properties": {
    "evidence_id": {"type": "string", "minLength": 1},
    "schema_version": {"type": "string", "enum": ["0.1-draft"]},
    "evidence_kind": {"type": "string", "enum": ["repo_health_evidence"]},
    "source": {"$ref": "#/$defs/source"},
    "subject": {"$ref": "#/$defs/subject"},
    "classification": {"$ref": "#/$defs/classification"},
    "finding": {"$ref": "#/$defs/finding"},
    "raw_handling": {"$ref": "#/$defs/raw_handling"},
    "trust": {"$ref": "#/$defs/trust"},
    "effects": {"$ref": "#/$defs/effects"},
    "residual_risks": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false,
  "$defs": {
    "execution_mode": {
      "type": "string",
      "enum": [
        "native_static",
        "imported_report",
        "local_no_network",
        "docker_isolated",
        "sandbox_observer",
        "synthetic_fixture"
      ]
    },
    "trust_level": {
      "type": "string",
      "enum": [
        "untrusted_import",
        "schema_validated",
        "redaction_validated",
        "commit_bound",
        "policy_bound",
        "docker_isolated_reproduced",
        "attested_binary_reproduced"
      ]
    },
    "category": {
      "type": "string",
      "enum": [
        "secret",
        "known_vulnerability",
        "sbom",
        "ci_cd",
        "runtime_behavior",
        "repo_posture",
        "sandbox_observation",
        "external_scanner",
        "approval",
        "limitation"
      ]
    },
    "source": {
      "type": "object",
      "required": [
        "tool_name",
        "tool_version",
        "adapter_name",
        "adapter_version",
        "execution_mode"
      ],
      "properties": {
        "tool_name": {"type": "string", "minLength": 1},
        "tool_version": {"type": "string", "minLength": 1},
        "adapter_name": {"type": "string", "minLength": 1},
        "adapter_version": {"type": "string", "minLength": 1},
        "execution_mode": {"$ref": "#/$defs/execution_mode"}
      },
      "additionalProperties": false
    },
    "subject": {
      "type": "object",
      "required": [
        "repo_identity",
        "commit",
        "tree_hash",
        "path_scope",
        "binding_kind"
      ],
      "properties": {
        "repo_identity": {"type": "string", "minLength": 1},
        "commit": {"type": ["string", "null"]},
        "tree_hash": {"type": ["string", "null"]},
        "snapshot_id": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "manifest_fingerprint": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "path_scope": {"type": "array", "items": {"type": "string"}},
        "binding_kind": {
          "type": "string",
          "enum": ["unbound", "path_bound", "commit_bound", "tree_bound", "snapshot_bound", "synthetic"]
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {"binding_kind": {"const": "snapshot_bound"}},
            "required": ["binding_kind"]
          },
          "then": {
            "required": ["snapshot_id", "manifest_fingerprint"]
          }
        }
      ]
    },
    "classification": {
      "type": "object",
      "required": [
        "category",
        "subcategory",
        "severity",
        "confidence",
        "confidence_reason"
      ],
      "properties": {
        "category": {"$ref": "#/$defs/category"},
        "subcategory": {"type": "string", "minLength": 1},
        "severity": {"type": "string", "enum": ["info", "warn", "block", "unknown"]},
        "confidence": {"type": "string", "enum": ["low", "medium", "high", "unknown"]},
        "confidence_reason": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "finding": {
      "type": "object",
      "required": [
        "present",
        "count",
        "locations",
        "redacted_summary"
      ],
      "properties": {
        "present": {"type": "boolean"},
        "count": {"type": "integer", "minimum": 0},
        "locations": {"type": "array", "items": {"$ref": "#/$defs/location"}},
        "redacted_summary": {"type": "string"}
      },
      "additionalProperties": false
    },
    "location": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {"type": "string"},
        "line": {"type": ["integer", "null"], "minimum": 1}
      },
      "additionalProperties": false
    },
    "raw_handling": {
      "type": "object",
      "required": [
        "raw_output_retained",
        "raw_stdout_retained",
        "raw_stderr_retained",
        "redaction_status",
        "redaction_failures"
      ],
      "properties": {
        "raw_output_retained": {"type": "boolean", "const": false},
        "raw_stdout_retained": {"type": "boolean", "const": false},
        "raw_stderr_retained": {"type": "boolean", "const": false},
        "redaction_status": {
          "type": "string",
          "enum": ["not_applicable", "redacted", "validated", "failed", "unknown"]
        },
        "redaction_failures": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "trust": {
      "type": "object",
      "required": [
        "level",
        "commit_bound",
        "signature_verified",
        "binary_attested",
        "limitations"
      ],
      "properties": {
        "level": {"$ref": "#/$defs/trust_level"},
        "commit_bound": {"type": "boolean"},
        "signature_verified": {"type": "boolean"},
        "binary_attested": {"type": "boolean"},
        "limitations": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "effects": {
      "type": "object",
      "required": [
        "can_lower_risk",
        "can_authorize_execution",
        "recommended_gate_effect"
      ],
      "properties": {
        "can_lower_risk": {"type": "boolean"},
        "can_authorize_execution": {"type": "boolean", "const": false},
        "recommended_gate_effect": {
          "type": "string",
          "enum": ["evidence_only", "requires_human_review", "allow_limited", "warn", "quarantine", "block"]
        }
      },
      "additionalProperties": false
    }
  }
}
